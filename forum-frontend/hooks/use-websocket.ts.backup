'use client'

import { useEffect, useRef, useState, useCallback } from 'react'
import { Client } from '@stomp/stompjs'
import SockJS from 'sockjs-client'
import { OnlineUser, UserStatus, OnlineCount, Notification, NotificationCount } from '@/lib/types'

interface UseWebSocketProps {
  onUserStatusChange?: (status: UserStatus) => void
  onOnlineCountChange?: (count: OnlineCount) => void
  onOnlineUsersChange?: (users: OnlineUser[]) => void
  token?: string
  enabled?: boolean
}

interface WebSocketState {
  isConnected: boolean
  onlineUsers: OnlineUser[]
  onlineCount: number
  error: string | null
}

export function useWebSocket({
  onUserStatusChange,
  onOnlineCountChange,
  onOnlineUsersChange,
  token,
  enabled = true,
}: UseWebSocketProps = {}) {
  const clientRef = useRef<Client | null>(null)
  const heartbeatIntervalRef = useRef<NodeJS.Timeout | null>(null)
  const reconnectTimeoutRef = useRef<NodeJS.Timeout | null>(null)
  const [reconnectAttempts, setReconnectAttempts] = useState(0)
  const maxReconnectAttempts = 5
  
  const [state, setState] = useState<WebSocketState>({
    isConnected: false,
    onlineUsers: [],
    onlineCount: 0,
    error: null,
  })

  const cleanup = useCallback(() => {
    if (heartbeatIntervalRef.current) {
      clearInterval(heartbeatIntervalRef.current)
      heartbeatIntervalRef.current = null
    }
    if (reconnectTimeoutRef.current) {
      clearTimeout(reconnectTimeoutRef.current)
      reconnectTimeoutRef.current = null
    }
  }, [])

  const startHeartbeat = useCallback(() => {
    if (heartbeatIntervalRef.current) {
      clearInterval(heartbeatIntervalRef.current)
    }
    
    heartbeatIntervalRef.current = setInterval(() => {
      if (clientRef.current?.connected) {
        try {
          clientRef.current.publish({
            destination: '/app/heartbeat',
            body: 'ping'
          })
        } catch (error) {
          console.error('Failed to send heartbeat:', error)
        }
      }
    }, 30000) // Send heartbeat every 30 seconds
  }, [])

  const connect = useCallback(() => {
    const authToken = token || localStorage.getItem('authToken')
    
    if (!authToken || !enabled) {
      console.log('WebSocket: No authentication token found or not enabled')
      setState(prev => ({ ...prev, error: 'No authentication token found' }))
      return
    }
    
    // Check if token is expired
    try {
      const [, payload] = authToken.split('.')
      const decoded = JSON.parse(atob(payload.replace(/-/g, '+').replace(/_/g, '/')))
      if (decoded.exp && decoded.exp * 1000 < Date.now()) {
        console.log('WebSocket: Token is expired, clearing authentication')
        localStorage.removeItem('authToken')
        localStorage.removeItem('username')
        setState(prev => ({ ...prev, error: 'Authentication token expired' }))
        // Trigger re-authentication by reloading the page
        window.location.reload()
        return
      }
    } catch (e) {
      console.error('WebSocket: Failed to decode token:', e)
    }
    
    console.log('WebSocket: Attempting to connect with token:', authToken.substring(0, 20) + '...')

    if (clientRef.current?.connected) {
      console.log('WebSocket: Already connected, skipping connection attempt')
      return // Already connected
    }

    // Deactivate any existing client before creating a new one
    if (clientRef.current) {
      console.log('WebSocket: Deactivating existing client before reconnection')
      clientRef.current.deactivate()
      clientRef.current = null
    }

    const client = new Client({
      webSocketFactory: () => {
        return new SockJS('http://localhost:8080/ws')
      },
      connectHeaders: {
        Authorization: `Bearer ${authToken}`
      },
      debug: (str) => {
        console.log('STOMP Debug:', str)
      },
      reconnectDelay: Math.min(1000 * Math.pow(2, reconnectAttempts), 30000),
      heartbeatIncoming: 4000,
      heartbeatOutgoing: 4000,
    })

    client.onConnect = () => {
      console.log('WebSocket: Successfully connected to', 'http://localhost:8080/ws')
      setState(prev => ({ 
        ...prev, 
        isConnected: true, 
        error: null 
      }))
      setReconnectAttempts(0)
      startHeartbeat()

      // Subscribe to topics
      client.subscribe('/topic/user-status', (message) => {
        try {
          const status: UserStatus = JSON.parse(message.body)
          onUserStatusChange?.(status)
        } catch (error) {
          console.error('Error parsing user status message:', error)
        }
      })

      client.subscribe('/topic/online-count', (message) => {
        try {
          const count: OnlineCount = JSON.parse(message.body)
          setState(prev => ({ ...prev, onlineCount: count.count }))
          onOnlineCountChange?.(count)
        } catch (error) {
          console.error('Error parsing online count message:', error)
        }
      })

      client.subscribe('/topic/online-users', (message) => {
        try {
          const users: OnlineUser[] = JSON.parse(message.body)
          setState(prev => ({ ...prev, onlineUsers: users }))
          onOnlineUsersChange?.(users)
        } catch (error) {
          console.error('Error parsing online users message:', error)
        }
      })

      client.subscribe('/user/queue/heartbeat-response', (message) => {
        // Heartbeat response received
        console.log('Heartbeat response:', message.body)
      })

      // Subscribe to user-specific notification queues
      client.subscribe('/user/queue/notifications', (message) => {
        try {
          const notification: Notification = JSON.parse(message.body)
          // Dispatch custom event for notification components to listen to
          window.dispatchEvent(new CustomEvent('notification-received', { detail: notification }))
        } catch (error) {
          console.error('Error parsing notification message:', error)
        }
      })

      client.subscribe('/user/queue/unread-count', (message) => {
        try {
          const countData: NotificationCount = JSON.parse(message.body)
          // Dispatch custom event for notification components to listen to
          window.dispatchEvent(new CustomEvent('unread-count-updated', { detail: countData }))
        } catch (error) {
          console.error('Error parsing unread count message:', error)
        }
      })

      // Request initial online users and count
      setTimeout(() => {
        if (client.connected) {
          client.publish({
            destination: '/app/online-users',
            body: ''
          })
          client.publish({
            destination: '/app/online-count',
            body: ''
          })
        }
      }, 100)
    }

    client.onStompError = (frame) => {
      console.error('WebSocket STOMP Error:', frame.headers['message'])
      console.error('WebSocket Error Frame:', frame)
      setState(prev => ({ 
        ...prev, 
        isConnected: false, 
        error: frame.headers['message'] || 'WebSocket connection error' 
      }))
    }

    client.onWebSocketClose = () => {
      console.log('WebSocket connection closed')
      setState(prev => ({ ...prev, isConnected: false }))
      cleanup()
      
      // Attempt to reconnect if not manually disconnected and under attempt limit
      if (reconnectAttempts < maxReconnectAttempts) {
        const delay = Math.min(1000 * Math.pow(2, reconnectAttempts), 30000)
        console.log(`Attempting to reconnect in ${delay}ms (attempt ${reconnectAttempts + 1}/${maxReconnectAttempts})`)
        
        reconnectTimeoutRef.current = setTimeout(() => {
          setReconnectAttempts(prev => prev + 1)
          connect()
        }, delay)
      } else {
        setState(prev => ({ 
          ...prev, 
          error: 'Maximum reconnection attempts reached' 
        }))
      }
    }

    client.onWebSocketError = (error) => {
      console.error('WebSocket Error:', error)
      setState(prev => ({ 
        ...prev, 
        error: 'WebSocket connection failed' 
      }))
    }

    clientRef.current = client
    client.activate()
  }, [startHeartbeat, cleanup, reconnectAttempts, onUserStatusChange, onOnlineCountChange, onOnlineUsersChange, token, enabled])

  const disconnect = useCallback(() => {
    cleanup()
    setReconnectAttempts(0)
    
    if (clientRef.current) {
      clientRef.current.deactivate()
      clientRef.current = null
    }
    
    setState(prev => ({ 
      ...prev, 
      isConnected: false, 
      error: null 
    }))
  }, [cleanup])

  const sendHeartbeat = useCallback(() => {
    if (clientRef.current?.connected) {
      clientRef.current.publish({
        destination: '/app/heartbeat',
        body: 'ping'
      })
    }
  }, [])

  const sendMessage = useCallback((destination: string, body: any) => {
    if (clientRef.current?.connected) {
      clientRef.current.publish({
        destination,
        body: typeof body === 'string' ? body : JSON.stringify(body)
      })
    }
  }, [])

  useEffect(() => {
    // Auto-connect if token exists and enabled
    const authToken = token || localStorage.getItem('authToken')
    console.log('WebSocket useEffect: Token exists?', !!authToken, 'Enabled?', enabled)
    if (authToken && enabled && !clientRef.current?.connected) {
      connect()
    } else if (!enabled && clientRef.current?.connected) {
      disconnect()
    }

    return () => {
      disconnect()
    }
  }, [token, enabled]) // Re-run when token or enabled changes

  return {
    ...state,
    connect,
    disconnect,
    sendHeartbeat,
    sendMessage,
    reconnectAttempts,
    maxReconnectAttempts,
  }
}